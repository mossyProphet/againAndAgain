{
  "type": "sseth",
  "baseType": "merchant",

  "npcname": "Trader AI",

  "damageTeamType": "assistant",
  "damageTeam": 1,

  "persistent": true,
  "innateStatusEffects": [ "invulnerable", "colorblue" ],
  "scriptConfig": {

    "reactions": {
