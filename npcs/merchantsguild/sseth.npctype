    "dialog": {
      "merchant": {
        "start": {
          "default": {
            "default": [
              "Trade protocol initialized. Session: #${randomId}",
              "Product catalog access granted. Select category",
              "Purchase interface activated. Input request"
            ]
          }
        },
        "welcome": {
          "default": {
            "default": [
              "Welcome package v3.1 loaded. Daily deals available",
              "Customer recognition... Profile: ${playerLevel}. Recommendations generated",
              "Terminal ready for transactions. Specials: ${dailyItems}"
            ]
          }
        },
        "end": {
          "default": {
            "default": [
              "Session terminated. Code: 0xTRD_SUCCESS",
              "Remember to rate service at feedback terminal",
              "POS system shutdown. Until next transaction!"
            ]
          }
        },
        "follow": "/dialog/merchant.config:follow",
        "tout": {
          "default": {
            "default": [
              "Alert! ${discount}% discount in ${category} segment",
              "Active shoppers receive bonus loyalty units",
              "Update loyalty firmware for premium goods access"
            ]
          }
        }
      }
