      [
        1.0,
        {
          "personality": "normal",
          "reactions": {}
        }
      ]
    ],
    "behaviorConfig": {
      "play": false,
      "chat": false
    },

    "questGenerator": {
      "pools": [],
      "enableParticipation": false
    },

    "merchant": {
      "waitTime": 40,
      "storeRadius": 8,
      "categories": {
        "human": [ "sseth" ]
      },

      //"rotateStock": true,
      //"rotationTime": 80,

      "buyFactorRange": [ 1.0, 3.0 ],
      "sellFactorRange": [ 0.2, 0.5 ],
      "numItems": 8,
      "paneLayoutOverride": {
        "windowtitle": {
          "title": "Trade-Assistant AI",
          "subtitle": "Need some spice in life?"
        }
      }
    },

    "chatSounds": {
